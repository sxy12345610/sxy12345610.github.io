/* ============================================
   旅程页面样式
   ============================================ */

/* 页面标题 */
.page-title {
  font-size: 24px;
  font-weight: bold;
  color: #5d4e6d;
  text-align: center;
  margin-bottom: 30px;
  display: block;
}

/* 统计概览 */
.stats-overview {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  margin-bottom: 30px;
}

.stat-card {
  background: white;
  border-radius: 15px;
  padding: 20px;
  text-align: center;
  box-shadow: 0 4px 15px rgba(0,0,0,0.05);
}

.stat-num {
  font-size: 32px;
  font-weight: bold;
  color: #667eea;
  display: block;
}

.stat-label {
  font-size: 12px;
  color: #8d7a9e;
  margin-top: 5px;
}

/* 今日心情 */
.mood-section {
  margin-bottom: 30px;
}

.section-title {
  font-size: 18px;
  font-weight: bold;
  color: #5d4e6d;
  margin-bottom: 15px;
  display: block;
}

.mood-card {
  background: linear-gradient(135deg, #ffb7b2 0%, #ffecd2 100%);
  border-radius: 15px;
  padding: 25px;
  text-align: center;
}

.mood-emoji {
  font-size: 48px;
  display: block;
  margin-bottom: 10px;
}

.mood-text {
  font-size: 16px;
  color: #5d4e6d;
}

.mood-empty {
  background: rgba(0,0,0,0.05);
  border-radius: 15px;
  padding: 30px;
  text-align: center;
}

.empty-text {
  font-size: 14px;
  color: #8d7a9e;
}

/* 情绪分布 */
.emotion-chart {
  margin-bottom: 30px;
}

.chart-bars {
  background: white;
  border-radius: 15px;
  padding: 20px;
  box-shadow: 0 4px 15px rgba(0,0,0,0.05);
}

.bar-item {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.bar-item:last-child {
  margin-bottom: 0;
}

.bar-label {
  width: 45px;
  font-size: 12px;
  color: #5d4e6d;
}

.bar-container {
  flex: 1;
  height: 12px;
  background: #f0f0f0;
  border-radius: 6px;
  margin: 0 10px;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 6px;
  transition: width 0.5s ease;
}

.bar-value {
  width: 30px;
  font-size: 12px;
  color: #8d7a9e;
  text-align: right;
}

/* 成就系统 */
.achievements-section {
  margin-bottom: 30px;
}

.achievements-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15px;
}

.achievement-item {
  background: white;
  border-radius: 15px;
  padding: 15px;
  text-align: center;
  box-shadow: 0 4px 15px rgba(0,0,0,0.05);
}

.achievement-icon {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 10px;
  font-size: 24px;
}

.achievement-name {
  font-size: 13px;
  font-weight: bold;
  color: #5d4e6d;
  display: block;
  margin-bottom: 5px;
}

.achievement-desc {
  font-size: 11px;
  color: #8d7a9e;
}

/* 近期记录 */
.history-section {
  margin-bottom: 30px;
}

.history-list {
  background: white;
  border-radius: 15px;
  padding: 15px;
  box-shadow: 0 4px 15px rgba(0,0,0,0.05);
}

.history-item {
  display: flex;
  padding: 12px 0;
  border-bottom: 1px solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-time {
  width: 70px;
  font-size: 12px;
  color: #8d7a9e;
}

.history-content {
  flex: 1;
  font-size: 14px;
  color: #5d4e6d;
}

.empty-history {
  padding: 30px;
  text-align: center;
}

/* 分享按钮 */
.share-section {
  margin-bottom: 30px;
}

.share-btn {
  width: 100%;
  padding: 15px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: none;
  border-radius: 15px;
  font-size: 16px;
  font-weight: bold;
  color: white;
}

.share-btn:active {
  transform: scale(0.98);
}
