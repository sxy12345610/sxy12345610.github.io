/* ============================================
   心情卡片页面样式 - 优化版
   ============================================ */

/* 页面基础容器 */
.container {
  min-height: 100vh;
  padding: 0 24rpx 200rpx;
  box-sizing: border-box;
}

/* 页面头部 */
.page-header {
  padding: 32rpx 0 24rpx;
  text-align: center;
}

.page-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #5d4e6d;
  display: block;
  animation: fadeInDown 0.5s ease-out;
}

/* 情绪选择区域 */
.emotion-page {
  padding: 20rpx 0;
}

.emotion-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  padding: 0 8rpx;
}

.emotion-card {
  background: white;
  border-radius: 24rpx;
  padding: 28rpx 12rpx;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.06);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 4rpx solid transparent;
  min-height: 160rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.emotion-card:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,0.1);
}

.emotion-card.selected {
  border-color: #ffb7b2;
  transform: scale(1.05);
  box-shadow: 0 16rpx 48rpx rgba(255, 183, 178, 0.4);
  animation: cardBounce 0.4s ease-out;
}

.emotion-icon {
  font-size: 56rpx;
  display: block;
  margin-bottom: 10rpx;
}

.emotion-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #5d4e6d;
}

/* 确认按钮 */
.confirm-btn {
  width: 90%;
  margin: 32rpx auto 0;
  background: linear-gradient(135deg, #ffb7b2 0%, #ffecd2 100%);
  border: none;
  padding: 26rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #5d4e6d;
  border-radius: 100rpx;
  box-shadow: 0 12rpx 40rpx rgba(255, 183, 178, 0.4);
  transition: all 0.3s ease;
}

.confirm-btn:active {
  transform: translateY(4rpx);
  box-shadow: 0 8rpx 24rpx rgba(255, 183, 178, 0.3);
}

/* ============================================
   卡片展示区域 - 核心优化
   ============================================ */

.cards-section {
  animation: pageFadeIn 0.5s ease-out;
  padding-bottom: 40rpx;
}

.cards-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  padding: 0 8rpx;
}

.card-item {
  width: 100%;
  max-width: 680rpx;
  perspective: 2000rpx;
  opacity: 0;
  transform: translateY(50rpx);
  animation: cardSlideIn 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.card-item:nth-child(1) { animation-delay: 0.1s; }
.card-item:nth-child(2) { animation-delay: 0.25s; }
.card-item:nth-child(3) { animation-delay: 0.4s; }

/* 卡片基础样式 */
.card {
  width: 100%;
  height: 520rpx;
  position: relative;
}

.flip-card-inner {
  position: relative;
  width: 100%;
  height: 100%;
  transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  transform-style: preserve-3d;
}

.card.flipped .flip-card-inner {
  transform: rotateY(180deg);
}

.card-front,
.card-back {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(0,0,0,0.1);
}

.card-front {
  background: white;
  display: flex;
  flex-direction: column;
}

.card-back {
  background: linear-gradient(145deg, #667eea 0%, #764ba2 100%);
  transform: rotateY(180deg);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

.card-back-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  animation: pulse 2s infinite;
}

.card-back-text {
  font-size: 32rpx;
  color: white;
  text-align: center;
  line-height: 1.7;
  word-break: break-word;
}

/* 卡片内容区域 */
.card-content {
  flex: 1;
  padding: 28rpx 28rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
}

.emotion-tag {
  font-size: 22rpx;
  padding: 8rpx 24rpx;
  border-radius: 40rpx;
  margin-bottom: 16rpx;
  color: white;
  font-weight: bold;
}

.story-text {
  font-size: 28rpx;
  color: #5d4e6d;
  text-align: center;
  line-height: 1.7;
  margin-bottom: 16rpx;
  word-break: break-word;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.challenge-box {
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 20rpx;
  padding: 18rpx 20rpx;
  width: 100%;
  margin-bottom: 12rpx;
}

.challenge-label {
  font-size: 20rpx;
  color: #8d7a9e;
  margin-bottom: 6rpx;
  display: block;
  text-align: center;
}

.challenge-text {
  font-size: 24rpx;
  color: #5d4e6d;
  font-weight: 500;
  text-align: center;
  display: block;
}

.small-action {
  font-size: 20rpx;
  color: #667eea;
  margin-bottom: 8rpx;
  text-align: center;
}

.social-count {
  font-size: 20rpx;
  color: #8d7a9e;
  text-align: center;
}

.count-number {
  font-weight: bold;
  color: #5d4e6d;
}

/* 卡片底部区域 */
.card-footer {
  padding: 16rpx 28rpx 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.complete-btn {
  background: linear-gradient(135deg, #84fab0 0%, #8fd3f4 100%);
  border: none;
  padding: 16rpx 48rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  font-weight: bold;
  color: #5d4e6d;
  transition: all 0.3s ease;
}

.complete-btn:active {
  transform: scale(1.05);
}

.complete-btn.completed {
  background: linear-gradient(135deg, #c8e6c9 0%, #b2dfdb 100%);
  color: #4caf50;
}

/* 消息输入区域 */
.message-input-area {
  margin: 40rpx auto 0;
  max-width: 680rpx;
  background: white;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.06);
}

.input-label {
  font-size: 28rpx;
  color: #5d4e6d;
  margin-bottom: 16rpx;
  display: block;
  font-weight: bold;
}

.message-input {
  width: 100%;
  padding: 20rpx;
  border: 3rpx solid #e9ecef;
  border-radius: 16rpx;
  font-size: 28rpx;
  outline: none;
  margin-bottom: 16rpx;
  box-sizing: border-box;
  background: #fafafa;
}

.submit-btn {
  width: 100%;
  padding: 22rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: none;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: white;
}

.submit-btn:active {
  transform: translateY(2rpx);
}

/* 按钮组 */
.btn-group {
  display: flex;
  gap: 24rpx;
  margin: 40rpx auto 0;
  max-width: 680rpx;
}

.btn {
  flex: 1;
  padding: 24rpx;
  border: none;
  border-radius: 28rpx;
  font-size: 28rpx;
  font-weight: bold;
  transition: all 0.3s ease;
}

.btn-primary {
  background: linear-gradient(135deg, #ffb7b2 0%, #ffecd2 100%);
  color: #5d4e6d;
}

.btn-secondary {
  background: white;
  color: #5d4e6d;
  border: 3rpx solid #e9ecef;
}

.btn:active {
  transform: translateY(-4rpx);
}

/* 今日已抽卡提示 */
.drawn-tip {
  text-align: center;
  padding: 80rpx 32rpx;
  animation: fadeIn 0.5s ease-out;
}

.tip-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 32rpx;
}

.tip-text {
  font-size: 32rpx;
  color: #5d4e6d;
}

/* ============================================
   动画效果
   ============================================ */

@keyframes cardSlideIn {
  from {
    opacity: 0;
    transform: translateY(60rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes cardBounce {
  0% { transform: scale(1); }
  50% { transform: scale(1.08); }
  100% { transform: scale(1.05); }
}

@keyframes pageFadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

/* ============================================
   夜间模式样式
   ============================================ */

.night-mode {
  background: linear-gradient(180deg, #0d0d1a 0%, #1a1a3e 100%);
  min-height: 100vh;
}

.night-mode .page-title {
  color: #e8e8e8;
}

.night-mode .emotion-grid {
  gap: 16rpx;
}

.night-mode .emotion-card {
  background: #1a1a3e;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.3);
}

.night-mode .emotion-name {
  color: #e8e8e8;
}

.night-mode .emotion-card.selected {
  box-shadow: 0 16rpx 48rpx rgba(102, 126, 234, 0.4);
}

.night-mode .confirm-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.night-mode .card-front {
  background: #1a1a3e;
  box-shadow: 0 12rpx 40rpx rgba(0,0,0,0.3);
}

.night-mode .card-content {
  background: #1a1a3e;
}

.night-mode .story-text {
  color: #e8e8e8;
}

.night-mode .challenge-box {
  background: rgba(255,255,255,0.08);
}

.night-mode .challenge-text {
  color: #e8e8e8;
}

.night-mode .challenge-label {
  color: #a8a8c8;
}

.night-mode .small-action {
  color: #a8b4fc;
}

.night-mode .social-count {
  color: #a8a8c8;
}

.night-mode .count-number {
  color: #e8e8e8;
}

.night-mode .message-input-area {
  background: #1a1a3e;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.3);
}

.night-mode .input-label {
  color: #e8e8e8;
}

.night-mode .message-input {
  background: #2a2a4e;
  border-color: #3a3a5e;
  color: #e8e8e8;
}

.night-mode .btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.night-mode .btn-secondary {
  background: #1a1a3e;
  color: #e8e8e8;
  border-color: #3a3a5e;
}

.night-mode .tip-text {
  color: #e8e8e8;
}

.night-mode .emotion-tag {
  opacity: 0.95;
}

.night-mode .card-back {
  background: linear-gradient(145deg, #2d2d5e 0%, #1a1a3e 100%);
}

.night-mode .card-back-text {
  color: #e8e8e8;
}

/* ============================================
   响应式适配
   ============================================ */

/* 大屏幕适配 */
@media (screen and (min-width: 750rpx) {
  .cards-wrapper {
    max-width: 720rpx;
    margin: 0 auto;
  }

  .card {
    height: 540rpx;
  }

  .story-text {
    font-size: 30rpx;
  }
}

/* ============================================
   夜间模式切换按钮
   ============================================ */

.night-mode-toggle {
  position: fixed;
  top: 120rpx;
  right: 20rpx;
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  z-index: 100;
  transition: all 0.3s ease;
}

.night-mode-toggle:active {
  transform: scale(0.95);
}

.toggle-icon {
  font-size: 40rpx;
}

.night-mode .night-mode-toggle {
  background: rgba(26, 26, 62, 0.9);
}

/* ============================================
   漂浮弹幕
   ============================================ */

.messages-wall {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 50;
  overflow: hidden;
}

.message-item {
  position: absolute;
  left: -300rpx;
  background: linear-gradient(135deg, rgba(255, 182, 178, 0.9) 0%, rgba(255, 236, 210, 0.9) 100%);
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: #5d4e6d;
  white-space: nowrap;
  animation: floatAcross linear forwards;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

@keyframes floatAcross {
  from {
    transform: translateX(0);
    opacity: 1;
  }
  to {
    transform: translateX(calc(100vw + 300rpx));
    opacity: 0.8;
  }
}

.night-mode .message-item {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.8) 0%, rgba(118, 75, 162, 0.8) 100%);
  color: #e8e8e8;
}