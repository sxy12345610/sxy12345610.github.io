/* ============================================
   身份卡页面样式
   ============================================ */

/* 隐藏的canvas用于生成图片 */
.hidden-canvas {
  position: fixed;
  top: -1000px;
  left: -1000px;
  width: 300px;
  height: 400px;
}

/* 页面标题 */
.page-title {
  font-size: 24px;
  font-weight: bold;
  color: #5d4e6d;
  text-align: center;
  margin-bottom: 30px;
  display: block;
}

/* 身份卡 */
.identity-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20px;
  padding: 25px;
  margin-bottom: 30px;
  box-shadow: 0 15px 40px rgba(102, 126, 234, 0.4);
  position: relative;
  overflow: hidden;
}

.identity-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
}

.card-header {
  text-align: center;
  margin-bottom: 20px;
  position: relative;
  z-index: 1;
}

.card-title {
  font-size: 14px;
  color: rgba(255,255,255,0.8);
  display: block;
  margin-bottom: 5px;
}

.card-date {
  font-size: 12px;
  color: rgba(255,255,255,0.6);
}

.card-content {
  position: relative;
  z-index: 1;
}

.avatar-section {
  text-align: center;
  margin-bottom: 15px;
}

.avatar-emoji {
  font-size: 60px;
  display: block;
}

.identity-name {
  font-size: 28px;
  font-weight: bold;
  color: white;
  text-align: center;
  display: block;
  margin-bottom: 8px;
}

.identity-title {
  font-size: 14px;
  color: rgba(255,255,255,0.8);
  text-align: center;
  display: block;
  margin-bottom: 20px;
}

.identity-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20px;
  padding: 15px;
  background: rgba(255,255,255,0.1);
  border-radius: 15px;
}

.stat {
  text-align: center;
}

.stat-value {
  font-size: 24px;
  font-weight: bold;
  color: #ffd93d;
  display: block;
}

.stat-label {
  font-size: 12px;
  color: rgba(255,255,255,0.7);
}

.identity-description {
  background: rgba(255,255,255,0.1);
  border-radius: 12px;
  padding: 15px;
  margin-bottom: 15px;
}

.description-title {
  font-size: 12px;
  color: rgba(255,255,255,0.8);
  display: block;
  margin-bottom: 8px;
}

.description-text {
  font-size: 14px;
  color: white;
  line-height: 1.6;
}

.identity-message {
  background: linear-gradient(135deg, rgba(255,217,61,0.2), rgba(255,183,178,0.2));
  border-radius: 12px;
  padding: 15px;
}

.message-text {
  font-size: 14px;
  color: white;
  text-align: center;
  line-height: 1.6;
}

.card-footer {
  text-align: center;
  margin-top: 20px;
  padding-top: 15px;
  border-top: 1px solid rgba(255,255,255,0.2);
  position: relative;
  z-index: 1;
}

.footer-text {
  font-size: 11px;
  color: rgba(255,255,255,0.5);
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 15px;
  margin-bottom: 30px;
}

.generate-btn, .save-btn {
  flex: 1;
  padding: 15px;
  border: none;
  border-radius: 15px;
  font-size: 14px;
  font-weight: bold;
  transition: all 0.3s ease;
}

.generate-btn {
  background: linear-gradient(135deg, #ffb7b2 0%, #ffecd2 100%);
  color: #5d4e6d;
}

.save-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.generate-btn:active, .save-btn:active {
  transform: scale(0.98);
}

/* 历史记录 */
.history-section {
  margin-bottom: 30px;
}

.section-title {
  font-size: 18px;
  font-weight: bold;
  color: #5d4e6d;
  margin-bottom: 15px;
  display: block;
}

.history-list {
  white-space: nowrap;
}

.history-card {
  display: inline-block;
  background: white;
  border-radius: 15px;
  padding: 15px 20px;
  margin-right: 12px;
  text-align: center;
  box-shadow: 0 4px 15px rgba(0,0,0,0.05);
}

.history-avatar {
  font-size: 32px;
  display: block;
  margin-bottom: 8px;
}

.history-date {
  font-size: 12px;
  color: #8d7a9e;
}

/* 二维码区域 */
.qr-section {
  margin-bottom: 30px;
}

.qr-container {
  background: white;
  border-radius: 15px;
  padding: 20px;
  text-align: center;
  box-shadow: 0 4px 15px rgba(0,0,0,0.05);
  position: relative;
}

.qrcode-canvas {
  width: 200px;
  height: 200px;
  margin: 0 auto;
}

.qr-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255,255,255,0.9);
  border-radius: 15px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.qr-icon {
  font-size: 40px;
  margin-bottom: 10px;
}

.qr-text {
  font-size: 14px;
  color: #8d7a9e;
}

/* 分享提示 */
.share-tip {
  background: linear-gradient(135deg, #e8f5e9 0%, #fce4ec 100%);
  border-radius: 15px;
  padding: 15px 20px;
  display: flex;
  align-items: center;
}

.tip-icon {
  font-size: 20px;
  margin-right: 10px;
}

.tip-content {
  font-size: 14px;
  color: #5d4e6d;
}
